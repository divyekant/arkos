---
const capabilities = [
  'Testing',
  'Documentation',
  'Memory',
  'Orchestration',
  'Project Setup',
  'Codebase Intelligence',
];
---

<section class="problem scroll-reveal">
  <div class="problem-inner">
    <h2 class="problem-heading">
      AI writes code.<br />
      <span class="shimmer-text">Who handles everything else?</span>
    </h2>

    <div class="capability-pills">
      {capabilities.map((cap) => (
        <span class="pill">{cap}</span>
      ))}
    </div>

    <p class="problem-answer">
      Arkos handles the other <span class="shimmer-text">80%</span>.
    </p>
  </div>
</section>

<style>
  .problem {
    position: relative;
    padding: 8rem 2rem;
    background-color: var(--arkos-bg, #0a0a0a);
    background-image:
      linear-gradient(rgba(212, 175, 55, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212, 175, 55, 0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .problem-inner {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .problem-heading {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--arkos-text, #e5e5e5);
    line-height: 1.3;
    margin: 0 0 3rem;
  }

  .capability-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 3rem;
  }

  .pill {
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    border: 1px solid var(--arkos-gold-border, rgba(212, 175, 55, 0.3));
    color: var(--arkos-gold, #d4af37);
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
    cursor: default;
  }

  .pill:hover {
    border-color: var(--arkos-gold, #d4af37);
    background: rgba(212, 175, 55, 0.08);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(212, 175, 55, 0.12);
  }

  .problem-answer {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: var(--arkos-text, #e5e5e5);
    font-weight: 600;
    margin: 0;
  }
</style>
