---
import ParticleCanvas from './ParticleCanvas.astro';
import NetworkGraph from './NetworkGraph.tsx';
---

<section class="hero">
  <div class="aurora">
    <div class="aurora-blob"></div>
    <div class="aurora-blob"></div>
    <div class="aurora-blob"></div>
  </div>

  <ParticleCanvas />

  <div class="hero-grid">
    <div class="hero-text">
      <h1 class="shimmer-text">ARKOS</h1>
      <p class="hero-headline">The other 80% of shipping software.</p>
      <p class="hero-value-prop">Open-source tools for testing, docs, memory, and orchestration — everything around your code that AI agents still can't handle alone.</p>
      <div class="hero-ctas">
        <a href="/tools/" class="cta cta-solid">Get Started</a>
        <a href="https://github.com/divyekant/arkos" class="cta cta-ghost" target="_blank" rel="noopener">View on GitHub</a>
      </div>
    </div>

    <div class="hero-visual">
      <NetworkGraph client:load />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--arkos-bg, #0a0a0a);
    overflow: hidden;
  }

  .hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    align-items: center;
    gap: 3rem;
    max-width: 1300px;
    padding: 2rem;
    width: 100%;
  }

  .hero-text {
    text-align: left;
  }

  .hero h1 {
    font-family: 'Philosopher', serif;
    font-size: clamp(2.5rem, 7vw, 5rem);
    letter-spacing: 0.15em;
    font-weight: 700;
    margin: 0 0 1.5rem;
    line-height: 1.1;
  }

  .hero-headline {
    color: var(--arkos-text, #e5e5e5);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 1rem;
  }

  .hero-value-prop {
    color: var(--arkos-text-muted, #a3a3a3);
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    line-height: 1.7;
    margin: 0 0 2rem;
    max-width: 480px;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 2rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .cta-solid {
    background: var(--arkos-gold, #d4af37);
    color: #0a0a0a;
  }

  .cta-solid:hover {
    background: var(--arkos-gold-bright, #f5d060);
    color: #0a0a0a;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.3);
  }

  .cta-ghost {
    background: transparent;
    color: var(--arkos-gold, #d4af37);
    border: 1.5px solid var(--arkos-gold-border, rgba(212, 175, 55, 0.3));
  }

  .cta-ghost:hover {
    border-color: var(--arkos-gold, #d4af37);
    color: var(--arkos-gold-bright, #f5d060);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.15);
  }

  /* Network graph */
  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 520px;
  }

  /* Mobile: stack vertically */
  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-text {
      text-align: center;
      order: 1;
    }

    .hero-visual {
      display: none;
    }

    .hero-value-prop {
      max-width: 100%;
    }

    .hero-ctas {
      justify-content: center;
    }
  }
</style>
