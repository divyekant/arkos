---
import ParticleCanvas from './ParticleCanvas.astro';
---

<section class="hero">
  <div class="aurora">
    <div class="aurora-blob"></div>
    <div class="aurora-blob"></div>
    <div class="aurora-blob"></div>
  </div>

  <ParticleCanvas />

  <div class="hero-content">
    <h1 class="shimmer-text">ARKOS</h1>
    <p class="hero-value-prop">The open-source toolkit that handles everything around your code — testing, docs, memory, orchestration — so you ship faster.</p>
    <p class="hero-tagline">Tools forged for the age of AI-native development</p>
    <div class="hero-ctas">
      <a href="/tools/" class="cta cta-solid">Get Started</a>
      <a href="https://github.com/divyekant/arkos" class="cta cta-ghost" target="_blank" rel="noopener">View on GitHub</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--arkos-bg, #0a0a0a);
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 2rem;
  }

  .hero h1 {
    font-family: 'Philosopher', serif;
    font-size: clamp(3rem, 10vw, 8rem);
    letter-spacing: 0.2em;
    font-weight: 700;
    margin: 0 0 1rem;
    line-height: 1.1;
  }

  .hero-value-prop {
    color: var(--arkos-text, #e5e5e5);
    font-size: clamp(1.05rem, 2.5vw, 1.3rem);
    text-wrap: balance;
    margin: 0 auto 1.5rem;
    max-width: 600px;
    line-height: 1.6;
  }

  .hero-tagline {
    color: var(--arkos-text-muted, #a3a3a3);
    font-size: clamp(0.9rem, 2vw, 1.1rem);
    text-wrap: balance;
    margin: 0 0 2.5rem;
    max-width: 500px;
    margin-inline: auto;
    font-style: italic;
    letter-spacing: 0.02em;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 2rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .cta-solid {
    background: var(--arkos-gold, #d4af37);
    color: #0a0a0a;
  }

  .cta-solid:hover {
    background: var(--arkos-gold-bright, #f5d060);
    color: #0a0a0a;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.3);
  }

  .cta-ghost {
    background: transparent;
    color: var(--arkos-gold, #d4af37);
    border: 1.5px solid var(--arkos-gold-border, rgba(212, 175, 55, 0.3));
  }

  .cta-ghost:hover {
    border-color: var(--arkos-gold, #d4af37);
    color: var(--arkos-gold-bright, #f5d060);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.15);
  }
</style>
